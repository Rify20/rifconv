# YouTube API Key (Dapatkan dari Google Cloud Console - GRATIS)
# Cara: https://console.cloud.google.com/ → Enable YouTube Data API v3 → Buat credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# RapidAPI Key (Opsional, untuk backup)
RAPIDAPI_KEY=your_rapidapi_key_here

NODE_ENV=production
PORT=3000
